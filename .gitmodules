[submodule "zinit/.local/share/zinit/zinit.git"]
	path = zinit/.local/share/zinit/zinit.git
	url = https://github.com/zdharma-continuum/zinit.git
[submodule "zsh/.config/zsh/theme/powerlevel10k/powerlevel10k"]
	path = zsh/.config/zsh/theme/powerlevel10k/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
[submodule "tmux/.local/share/tmux/plugins/tpm"]
	path = tmux/.local/share/tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm
[submodule "fzf/.local/share/fzf"]
	path = fzf/.local/share/fzf
	url = https://github.com/junegunn/fzf.git
