#
# wm-independent bindings
#

# Open terminal
shift + lalt - return : /Applications/Alacritty.app/Contents/MacOS/Alacritty;yabai -m window --toggle zoom-fullscreen

#
# yabai bindings
#
shift + lalt - q : yabai --stop-service

# Toggle float window
shift + lalt - space : yabai -m window --toggle float; yabai -m window --grid 9:9:1:1:7:7

# Layout
lalt - t : yabai -m space --layout bsp
lalt - f : yabai -m space --layout float

# Fullscreen
lalt - return : yabai -m window --toggle native-fullscreen
lalt - m : yabai -m window --toggle zoom-fullscreen


# Navigation
lalt - h : yabai -m window --focus west
lalt - j : yabai -m window --focus south
lalt - k : yabai -m window --focus north
lalt - l : yabai -m window --focus east
lalt - r : yabai -m window --focus recent
# 0x21 : [
lalt - 0x21 : yabai -m window --focus stack.prev || yabai -m window --focus stack.last
# 0x1E : ]
lalt - 0x1E : yabai -m window --focus stack.next || yabai -m window --focus stack.first


# Navigate workspaces
lalt - 0 : yabai -m space --focus recent
lalt - 1 : yabai -m space --focus 1
lalt - 2 : yabai -m space --focus 2
lalt - 3 : yabai -m space --focus 3
lalt - 4 : yabai -m space --focus 4
lalt - 5 : yabai -m space --focus 5
lalt - 6 : yabai -m space --focus 6
lalt - 7 : yabai -m space --focus 7
lalt - 8 : yabai -m space --focus 8
# 0x2B : <
lalt - 0x2F : yabai -m space --focus next
# 0x2F : >
lalt - 0x2B : yabai -m space --focus prev

# Moving windows
ctrl + lalt - h : yabai -m window --warp west
ctrl + lalt - j : yabai -m window --warp south
ctrl + lalt - k : yabai -m window --warp north
ctrl + lalt - l : yabai -m window --warp east

# swap window
shift + lalt - h : yabai -m window --swap west
shift + lalt - j : yabai -m window --swap south
shift + lalt - k : yabai -m window --swap north
shift + lalt - l : yabai -m window --swap east

# Move focus container to workspace
ctrl + lalt + cmd - h : yabai -m window --space prev; yabai -m space --focus prev
ctrl + lalt + cmd - l : yabai -m window --space next; yabai -m space --focus next
ctrl + lalt + cmd - 1 : yabai -m window --space 1; yabai -m space --focus 1
ctrl + lalt + cmd - 2 : yabai -m window --space 2; yabai -m space --focus 2
ctrl + lalt + cmd - 3 : yabai -m window --space 3; yabai -m space --focus 3
ctrl + lalt + cmd - 4 : yabai -m window --space 4; yabai -m space --focus 4
ctrl + lalt + cmd - 5 : yabai -m window --space 5; yabai -m space --focus 5
ctrl + lalt + cmd - 6 : yabai -m window --space 6; yabai -m space --focus 6
ctrl + lalt + cmd - 7 : yabai -m window --space 7; yabai -m space --focus 7
ctrl + lalt + cmd - 8 : yabai -m window --space 8; yabai -m space --focus 8

# create desktop and follow focus
shift + ctrl + cmd + lalt - n : yabai -m space --create && \
                  yabai -m window --space next && \
                  yabai -m space --focus next

ctrl + lalt - n : yabai -m space --create && \
                  yabai -m space --focus next

ctrl + lalt - x : yabai -m space --destroy

# move workspaces
# 0x2B : ,
shift + lalt - 0x2F : yabai -m space --swap next
# 0x2F : .
shift + lalt - 0x2B : yabai -m space --swap prev

# Resize windows
shift + lctrl + lalt - h : yabai -m window --resize left:-50:0; \
                  yabai -m window --resize right:-50:0
shift + lctrl + lalt - j : yabai -m window --resize bottom:0:50; \
                  yabai -m window --resize top:0:50
shift + lctrl + lalt - k : yabai -m window --resize top:0:-50; \
                  yabai -m window --resize bottom:0:-50
shift + lctrl + lalt - l : yabai -m window --resize right:50:0; \
                  yabai -m window --resize left:50:0

# Equalize size of windows
# 0x18 : =
lctrl + lalt - 0x18 : yabai -m space --balance

# Rotate window tree
lctrl + lalt - r : yabai -m space --rotate 90

# Enable / Disable gaps in current workspace
lctrl + lalt - g : yabai -m space --toggle padding; yabai -m space --toggle gap

